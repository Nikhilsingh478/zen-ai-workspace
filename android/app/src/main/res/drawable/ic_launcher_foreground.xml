<?xml version="1.0" encoding="utf-8"?>
<!--
  AI Matrix adaptive icon foreground.
  Canvas: 108dp × 108dp. Android safe zone: 72dp circle centred at (54,54).
  Design mirrors the public/icon.svg brand mark:
    • Outer kite/diamond  — sky-blue (#7DD3FC)
    • Inner diamond       — white (90% opacity)
    • Centre circle hole  — matches background (#0A0F1A)
  Coordinates are the SVG paths scaled from 512→108 (factor ≈ 0.211).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer kite: M54,17 L94,88 L54,71 L14,88 Z -->
    <path
        android:fillColor="#7DD3FC"
        android:pathData="M54,17 L94,88 L54,71 L14,88 Z" />

    <!-- Inner diamond (white): M54,34 L78,78 L54,66 L30,78 Z -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.92"
        android:pathData="M54,34 L78,78 L54,66 L30,78 Z" />

    <!-- Centre circle hole: cx=54 cy=51 r=6  (dark, matches background) -->
    <path
        android:fillColor="#0A0F1A"
        android:pathData="M54,45 A6,6 0 1,0 54,57 A6,6 0 1,0 54,45 Z" />

</vector>
